{
  "effortLevel": "high",
  "model": "opus",
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "Read",
      "Task",
      "WebFetch",
      "WebSearch",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(jot:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(pwd:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh issue status:*)",
      "Bash(gh search repos:*)",
      "Bash(gh search issues:*)",
      "Bash(gh search prs:*)",
      "Bash(gh run view:*)",
      "Bash(ansible-lint:*)",
      "Bash(ansible-playbook:*)",
      "Bash(pnpm audit:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm update:*)",
      "Bash(pnpm run:*)",
      "Bash(uv:*)",
      "Bash(codex exec:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(git clean:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(nc:*)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm uninstall:*)",
      "Read(**/.env*)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(**/*-key*)",
      "Read(**/*-token*)",
      "Read(**/*.key*)",
      "Read(**/*.token*)",
      "Read(**/*_key*)",
      "Read(**/*_token*)",
      "Read(**/secrets/**)",
      "Write(**/.env*)",
      "Write(**/secrets/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  }
